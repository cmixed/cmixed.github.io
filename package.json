{
  "name": "cmixed-homepage",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "blog": "tsx blog/build.ts",
    "build": "tsc --noEmit && vite build && tsx blog/build.ts",
    "preview": "vite preview",
    "lint": "eslint src/ blog/build.ts",
    "lint:fix": "eslint src/ blog/build.ts --fix",
    "format": "prettier --write 'src/**/*.ts' 'blog/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'blog/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "marked": "^18.0.5",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "~5.6.0",
    "typescript-eslint": "^8.63.0",
    "vite": "^6.0.0"
  }
}
